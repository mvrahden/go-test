package withsimplify //nolint:stdlib-test

import (
	"errors"
	"regexp"
	"testing"

	"github.com/mvrahden/go-test/pkg/gotest"
)

// === True with binary comparisons ===

func TestTrueComparisons(t *testing.T) {
	a, b := 1, 2
	gotest.Equal(t, a, b)          // want `use Equal instead of True for == comparison`
	gotest.NotEqual(t, a, b)       // want `use NotEqual instead of True for != comparison`
	gotest.Greater(t, a, b)        // want `use Greater instead of True for > comparison`
	gotest.GreaterOrEqual(t, a, b) // want `use GreaterOrEqual instead of True for >= comparison`
	gotest.Less(t, a, b)           // want `use Less instead of True for < comparison`
	gotest.LessOrEqual(t, a, b)    // want `use LessOrEqual instead of True for <= comparison`
}

// === True with nil checks — all nilable type categories ===

func TestTrueNilError(t *testing.T) {
	var err error
	gotest.NoError(t, err) // want `use NoError instead of True for error nil check`
	gotest.Error(t, err)   // want `use Error instead of True for error nil check`
	gotest.NoError(t, err) // want `use NoError instead of True for error nil check`
	gotest.Error(t, err)   // want `use Error instead of True for error nil check`
}

func TestTrueNilComparable(t *testing.T) {
	// pointer
	var p *int
	gotest.Zero(t, p)    // want `use Zero instead of True for nil check`
	gotest.NotZero(t, p) // want `use NotZero instead of True for nil check`

	// channel
	var ch chan int
	gotest.Zero(t, ch)    // want `use Zero instead of True for nil check`
	gotest.NotZero(t, ch) // want `use NotZero instead of True for nil check`

	// non-error interface
	var iface any
	gotest.Zero(t, iface)    // want `use Zero instead of True for nil check`
	gotest.NotZero(t, iface) // want `use NotZero instead of True for nil check`
}

func TestTrueNilNonComparable(t *testing.T) {
	// slice
	var s []int
	gotest.Nil(t, s)    // want `use Nil instead of True for nil check`
	gotest.NotNil(t, s) // want `use NotNil instead of True for nil check`

	// map
	var m map[string]int
	gotest.Nil(t, m)    // want `use Nil instead of True for nil check`
	gotest.NotNil(t, m) // want `use NotNil instead of True for nil check`

	// func
	var fn func()
	gotest.Nil(t, fn)    // want `use Nil instead of True for nil check`
	gotest.NotNil(t, fn) // want `use NotNil instead of True for nil check`
}

// === True with len checks ===

func TestTrueLen(t *testing.T) {
	s := []int{1, 2, 3}
	gotest.Empty(t, s)    // want `use Empty instead of True for len == 0 check`
	gotest.NotEmpty(t, s) // want `use NotEmpty instead of True for len == 0 check`
	gotest.NotEmpty(t, s) // want `use NotEmpty instead of True for len > 0 check`
	gotest.NotEmpty(t, s) // want `use NotEmpty instead of True for len >= 1 check`
	gotest.Len(t, s, 3)   // want `use Len instead of True for len comparison`
	gotest.Empty(t, s)    // want `use Empty instead of True for len == 0 check`
	gotest.NotEmpty(t, s) // want `use NotEmpty instead of True for len == 0 check`
	gotest.Len(t, s, 3)   // want `use Len instead of True for len comparison`
}

// === True with call expressions ===

func TestTrueCalls(t *testing.T) {
	s := "hello world"
	gotest.Contains(t, s, "hello")                           // want `use Contains instead of True for strings.Contains call`
	gotest.NoError(t, errors.New("x"))                       // want `use NoError instead of True for errors.Is nil check`
	gotest.ErrorIs(t, errors.New("x"), errors.New("target")) // want `use ErrorIs instead of True for errors.Is call`
	re := regexp.MustCompile(".*")
	gotest.Regexp(t, re, "hello") // want `use Regexp instead of True for MatchString call`
	gotest.Equal(t, 1, 2)         // want `use Equal instead of True for reflect.DeepEqual call`
}

// === True with negation ===

func TestTrueNegation(t *testing.T) {
	b := true
	gotest.False(t, b) // want `use False instead of True for negation`

	s := "hello"
	gotest.NotContains(t, s, "z") // want `use NotContains instead of True for negated strings.Contains call`
}

// === False with binary comparisons ===

func TestFalseComparisons(t *testing.T) {
	a, b := 1, 2
	gotest.NotEqual(t, a, b)       // want `use NotEqual instead of False for == comparison`
	gotest.Equal(t, a, b)          // want `use Equal instead of False for != comparison`
	gotest.LessOrEqual(t, a, b)    // want `use LessOrEqual instead of False for > comparison`
	gotest.Less(t, a, b)           // want `use Less instead of False for >= comparison`
	gotest.GreaterOrEqual(t, a, b) // want `use GreaterOrEqual instead of False for < comparison`
	gotest.Greater(t, a, b)        // want `use Greater instead of False for <= comparison`
}

// === False with nil checks — all nilable type categories ===

func TestFalseNilError(t *testing.T) {
	var err error
	gotest.Error(t, err)   // want `use Error instead of False for error nil check`
	gotest.NoError(t, err) // want `use NoError instead of False for error nil check`
}

func TestFalseNilComparable(t *testing.T) {
	// pointer
	var p *int
	gotest.NotZero(t, p) // want `use NotZero instead of False for nil check`
	gotest.Zero(t, p)    // want `use Zero instead of False for nil check`

	// channel
	var ch chan int
	gotest.NotZero(t, ch) // want `use NotZero instead of False for nil check`
	gotest.Zero(t, ch)    // want `use Zero instead of False for nil check`

	// non-error interface
	var iface any
	gotest.NotZero(t, iface) // want `use NotZero instead of False for nil check`
	gotest.Zero(t, iface)    // want `use Zero instead of False for nil check`
}

func TestFalseNilNonComparable(t *testing.T) {
	// slice
	var s []int
	gotest.NotNil(t, s) // want `use NotNil instead of False for nil check`
	gotest.Nil(t, s)    // want `use Nil instead of False for nil check`

	// map
	var m map[string]int
	gotest.NotNil(t, m) // want `use NotNil instead of False for nil check`
	gotest.Nil(t, m)    // want `use Nil instead of False for nil check`

	// func
	var fn func()
	gotest.NotNil(t, fn) // want `use NotNil instead of False for nil check`
	gotest.Nil(t, fn)    // want `use Nil instead of False for nil check`
}

// === False with len checks ===

func TestFalseLen(t *testing.T) {
	s := []int{1, 2, 3}
	gotest.NotEmpty(t, s) // want `use NotEmpty instead of False for len == 0 check`
	gotest.Empty(t, s)    // want `use Empty instead of False for len == 0 check`
	gotest.Empty(t, s)    // want `use Empty instead of False for len > 0 check`
	gotest.Empty(t, s)    // want `use Empty instead of False for len >= 1 check`
	gotest.NotEmpty(t, s) // want `use NotEmpty instead of False for len == 0 check`
}

// === False with call expressions ===

func TestFalseCalls(t *testing.T) {
	s := "hello world"
	gotest.NotContains(t, s, "xyz")  // want `use NotContains instead of False for strings.Contains call`
	gotest.NotEqual(t, 1, 2)         // want `use NotEqual instead of False for reflect.DeepEqual call`
	gotest.Error(t, errors.New("x")) // want `use Error instead of False for errors.Is nil check`
}

// === False with negation ===

func TestFalseNegation(t *testing.T) {
	b := true
	gotest.True(t, b) // want `use True instead of False for negation`

	s := "hello"
	gotest.Contains(t, s, "h") // want `use Contains instead of False for negated strings.Contains call`
}

// === Equal with special values ===

func TestEqualBoolLiteral(t *testing.T) {
	b := true
	gotest.True(t, b)  // want `use True instead of Equal for bool literal comparison`
	gotest.False(t, b) // want `use False instead of Equal for bool literal comparison`
	gotest.True(t, b)  // want `use True instead of Equal for bool literal comparison`
	gotest.False(t, b) // want `use False instead of Equal for bool literal comparison`
}

func TestEqualNil(t *testing.T) {
	// error
	var err error
	gotest.NoError(t, err) // want `use NoError instead of Equal for nil error comparison`
	gotest.NoError(t, err) // want `use NoError instead of Equal for nil error comparison`

	// pointer — comparable
	var p *int
	gotest.Zero(t, p) // want `use Zero instead of Equal for nil comparison`
	gotest.Zero(t, p) // want `use Zero instead of Equal for nil comparison`

	// channel — comparable
	var ch chan int
	gotest.Zero(t, ch) // want `use Zero instead of Equal for nil comparison`
	gotest.Zero(t, ch) // want `use Zero instead of Equal for nil comparison`

	// non-error interface — comparable
	var iface any
	gotest.Zero(t, iface) // want `use Zero instead of Equal for nil comparison`
	gotest.Zero(t, iface) // want `use Zero instead of Equal for nil comparison`

	// slice — non-comparable nilable
	var s []int
	gotest.Nil(t, s) // want `use Nil instead of Equal for nil comparison`
	gotest.Nil(t, s) // want `use Nil instead of Equal for nil comparison`

	// map — non-comparable nilable
	var m map[string]int
	gotest.Nil(t, m) // want `use Nil instead of Equal for nil comparison`
	gotest.Nil(t, m) // want `use Nil instead of Equal for nil comparison`
}

func TestEqualLen(t *testing.T) {
	s := []int{1, 2, 3}
	gotest.Empty(t, s)  // want `use Empty instead of Equal for len == 0 comparison`
	gotest.Empty(t, s)  // want `use Empty instead of Equal for len == 0 comparison`
	gotest.Len(t, s, 3) // want `use Len instead of Equal for len comparison`
	gotest.Len(t, s, 3) // want `use Len instead of Equal for len comparison`
}

// === NotEqual with special values ===

func TestNotEqualBoolLiteral(t *testing.T) {
	b := true
	gotest.False(t, b) // want `use False instead of NotEqual for bool literal comparison`
	gotest.True(t, b)  // want `use True instead of NotEqual for bool literal comparison`
	gotest.False(t, b) // want `use False instead of NotEqual for bool literal comparison`
	gotest.True(t, b)  // want `use True instead of NotEqual for bool literal comparison`
}

func TestNotEqualNil(t *testing.T) {
	// error
	var err error
	gotest.Error(t, err) // want `use Error instead of NotEqual for nil error comparison`
	gotest.Error(t, err) // want `use Error instead of NotEqual for nil error comparison`

	// pointer — comparable
	var p *int
	gotest.NotZero(t, p) // want `use NotZero instead of NotEqual for nil comparison`
	gotest.NotZero(t, p) // want `use NotZero instead of NotEqual for nil comparison`

	// channel — comparable
	var ch chan int
	gotest.NotZero(t, ch) // want `use NotZero instead of NotEqual for nil comparison`
	gotest.NotZero(t, ch) // want `use NotZero instead of NotEqual for nil comparison`

	// non-error interface — comparable
	var iface any
	gotest.NotZero(t, iface) // want `use NotZero instead of NotEqual for nil comparison`
	gotest.NotZero(t, iface) // want `use NotZero instead of NotEqual for nil comparison`

	// slice — non-comparable nilable
	var s []int
	gotest.NotNil(t, s) // want `use NotNil instead of NotEqual for nil comparison`
	gotest.NotNil(t, s) // want `use NotNil instead of NotEqual for nil comparison`

	// map — non-comparable nilable
	var m map[string]int
	gotest.NotNil(t, m) // want `use NotNil instead of NotEqual for nil comparison`
	gotest.NotNil(t, m) // want `use NotNil instead of NotEqual for nil comparison`
}

func TestNotEqualLen(t *testing.T) {
	s := []int{1, 2, 3}
	gotest.NotEmpty(t, s) // want `use NotEmpty instead of NotEqual for len == 0 comparison`
	gotest.NotEmpty(t, s) // want `use NotEmpty instead of NotEqual for len == 0 comparison`
}

// === Len with zero ===

func TestLenZero(t *testing.T) {
	s := []int{}
	gotest.Empty(t, s) // want `use Empty instead of Len for zero length check`
}

// === Greater / GreaterOrEqual with len ===

func TestGreaterLen(t *testing.T) {
	s := []int{1}
	gotest.NotEmpty(t, s) // want `use NotEmpty instead of Greater for len > 0 check`
	gotest.NotEmpty(t, s) // want `use NotEmpty instead of GreaterOrEqual for len >= 1 check`
}

// === Zero / NotZero with error ===

func TestZeroError(t *testing.T) {
	var err error
	gotest.NoError(t, err) // want `use NoError instead of Zero for error zero check`
	gotest.Error(t, err)   // want `use Error instead of NotZero for error zero check`
}

// === Contains with err.Error() ===

func TestContainsErrMsg(t *testing.T) {
	err := errors.New("something failed")
	gotest.ErrorContains(t, err, "failed") // want `use ErrorContains instead of Contains for err.Error\(\) contains check`
}

// === Correct usage — no diagnostics ===

func TestCorrectUsage(t *testing.T) {
	a, b := 1, 2
	gotest.Equal(t, a, b)
	gotest.NotEqual(t, a, b)
	gotest.Greater(t, a, b)
	gotest.True(t, true)
	gotest.False(t, false)

	var err error
	gotest.NoError(t, err)
	gotest.Error(t, err)

	s := []int{1}
	gotest.Empty(t, s)
	gotest.NotEmpty(t, s) //nolint:assertion-redundant // testing correct usage, not a redundant guard
	gotest.Len(t, s, 3)
	gotest.Contains(t, "hello", "h")

	// Nil/NotNil on slices, maps, funcs — correct usage
	var sl []int
	gotest.Nil(t, sl)
	gotest.NotNil(t, sl)
	var m map[string]int
	gotest.Nil(t, m)
	gotest.NotNil(t, m)
	var fn func()
	gotest.Nil(t, fn)
	gotest.NotNil(t, fn)

	// Len with nil object — semantically different from Empty, no suggestion
	gotest.Len(t, nil, 0)

	// ErrorIs/ErrorContains with valid arguments — no suggestions
	gotest.ErrorIs(t, err, errors.New("target"))
	gotest.ErrorContains(t, err, "substr")
}

// === func type — now has suggestions ===

func TestFuncNilComparison(t *testing.T) {
	var fn func()
	gotest.Nil(t, fn)    // want `use Nil instead of True for nil check`
	gotest.NotNil(t, fn) // want `use NotNil instead of True for nil check`
	gotest.NotNil(t, fn) // want `use NotNil instead of False for nil check`
	gotest.Nil(t, fn)    // want `use Nil instead of False for nil check`
	gotest.Nil(t, fn)    // want `use Nil instead of Equal for nil comparison`
	gotest.NotNil(t, fn) // want `use NotNil instead of NotEqual for nil comparison`
}

// === Nil/NotNil type guard ===

func TestNilTypeGuard(t *testing.T) {
	// error — should use NoError/Error
	var err error
	gotest.NoError(t, err) // want `use NoError instead of Nil for error nil check`
	gotest.Error(t, err)   // want `use Error instead of NotNil for error nil check`

	// pointer — should use Zero/NotZero
	var p *int
	gotest.Zero(t, p)    // want `use Zero instead of Nil for nil check`
	gotest.NotZero(t, p) // want `use NotZero instead of NotNil for nil check`

	// channel — should use Zero/NotZero
	var ch chan int
	gotest.Zero(t, ch)    // want `use Zero instead of Nil for nil check`
	gotest.NotZero(t, ch) // want `use NotZero instead of NotNil for nil check`

	// interface — should use Zero/NotZero
	var iface any
	gotest.Zero(t, iface)    // want `use Zero instead of Nil for nil check`
	gotest.NotZero(t, iface) // want `use NotZero instead of NotNil for nil check`

	// non-nilable — type guard error
	gotest.Nil(t, 42)    // want `type int is not nilable`
	gotest.NotNil(t, 42) // want `type int is not nilable`
	gotest.Nil(t, "x")   // want `type string is not nilable`
	gotest.Nil(t, true)  // want `type bool is not nilable`
}

// === Empty/NotEmpty type guard ===

func TestEmptyTypeGuard(t *testing.T) {
	// error — should use NoError/Error
	var err error
	gotest.NoError(t, err) // want `use NoError instead of Empty for error empty check`
	gotest.Error(t, err)   // want `use Error instead of NotEmpty for error empty check`

	// non-emptyable — type guard error
	gotest.Empty(t, 42)    // want `type int cannot be empty`
	gotest.NotEmpty(t, 42) // want `type int cannot be empty`
	gotest.Empty(t, true)  // want `type bool cannot be empty`

	// func — not emptyable
	var fn func()
	gotest.Empty(t, fn)    // want `type func\(\) cannot be empty`
	gotest.NotEmpty(t, fn) // want `type func\(\) cannot be empty`
}

// === ErrorIs / ErrorContains type guard ===

func TestErrorIsTypeGuard(t *testing.T) {
	var err error
	gotest.NoError(t, err) // want `use NoError instead of ErrorIs for nil target`
}

func TestErrorContainsTypeGuard(t *testing.T) {
	var err error
	gotest.Error(t, err) // want `use Error instead of ErrorContains for empty contains string`
}

// === With message args — preserved in fix ===

func TestWithMsgArgs(t *testing.T) {
	a, b := 1, 2
	gotest.Equal(t, a, b, "values should match") // want `use Equal instead of True for == comparison`
}
