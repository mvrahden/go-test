	if ƒcfg.FailFast && t.Failed() {
		return
	}

	t.Run("TestCollectResults", func(it *testing.T) {
		ttt := gotest.NewT(it)
		if ƒcfg.Timeout > 0 {
			ttt = gotest.NewTWithDeadline(it, ƒcfg.Timeout)
		}
		defer s.AfterEach(ttt)
		s.BeforeEach(ttt)
		ƒƒ_GOTEST_exec(s.TestCollectResults, ttt)
	})
	if ƒcfg.FailFast && t.Failed() {
		return
	}

}

