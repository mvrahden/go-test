{
  "name": "vscode-gotest",
  "displayName": "Go Test Suites",
  "description": "Test Explorer, CodeLens, and debug integration for go-test suites",
  "version": "0.1.0",
  "publisher": "mvrahden",
  "license": "MIT",
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "workspaceContains:**/*_test.go"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gotest.runTest",
        "title": "Go Test: Run"
      },
      {
        "command": "gotest.debugTest",
        "title": "Go Test: Debug"
      },
      {
        "command": "gotest.refreshTests",
        "title": "Go Test: Refresh"
      },
      {
        "command": "gotest.showFocusedTests",
        "title": "Go Test: Show Focused Tests"
      },
      {
        "command": "gotest.showSpecView",
        "title": "Go Test: Show Spec View"
      },
      {
        "command": "gotest.startWatch",
        "title": "Go Test: Start Watch"
      },
      {
        "command": "gotest.stopWatch",
        "title": "Go Test: Stop Watch"
      },
      {
        "command": "gotest.scaffold",
        "title": "Go Test: Scaffold Suite"
      },
      {
        "command": "gotest.scaffoldTarget",
        "title": "Go Test: Scaffold Target"
      },
      {
        "command": "gotest.copyCoverage",
        "title": "Go Test: Copy Coverage Summary",
        "icon": "$(copy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gotest.copyCoverage",
          "when": "view == workbench.view.testCoverage",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Go Test Suites",
      "properties": {
        "gotest.modulePath": {
          "type": "string",
          "default": "github.com/mvrahden/go-test/cmd/gotest",
          "scope": "resource",
          "description": "Go module path for gotest CLI (used with 'go run')"
        },
        "gotest.cliPath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Override: path to a pre-installed gotest binary (bypasses 'go run')"
        },
        "gotest.discoverOnSave": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Re-run discovery when a _test.go file is saved"
        },
        "gotest.showCodeLens": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "description": "Show Run/Debug CodeLens above suites and methods"
        },
        "gotest.showFocusWarnings": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "description": "Show diagnostics for F_ prefixed tests"
        },
        "gotest.testFlags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "description": "Additional flags passed to gotest test"
        },
        "gotest.buildFlags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "description": "Additional build flags passed to dlv"
        },
        "gotest.buildTags": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Comma-separated Go build tags (e.g. 'integration,e2e'). Passed to discovery, test runs, and overlays."
        },
        "gotest.coverOnRun": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Collect coverage data alongside normal test runs"
        },
        "gotest.coverOnSave": {
          "type": "boolean",
          "default": false,
          "scope": "resource",
          "description": "Re-run package coverage when a .go file is saved (opt-in)"
        },
        "gotest.specView.autoRefresh": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "description": "Auto-refresh spec view panel after test runs"
        },
        "gotest.watch.autoRestart": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "description": "Auto-restart watch process on crash"
        },
        "gotest.watch.scope": {
          "type": "string",
          "default": "./...",
          "scope": "resource",
          "description": "Default package scope for watch mode"
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.101.0",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
